# Glowmi Environment Variables
# Copy this file to .env and fill in the values

# Google Gemini API Key (AI beauty analysis)
# Get from: https://aistudio.google.com/apikey
# LOCAL DEV ONLY — set this to call Gemini directly from the browser.
# In production, use GEMINI_API_KEY (server-side, no VITE_ prefix) instead.
VITE_GEMINI_API_KEY=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-side only (Cloudflare Pages > Settings > Variables and Secrets) ---

# Gemini API Key (server-side proxy, Type: Secret)
# Production uses /api/gemini proxy so the key is never sent to the browser.
# GEMINI_API_KEY=

# Discord Webhook URL (new signup notifications)
# DISCORD_WEBHOOK_URL=

# --- RAG (Retrieval-Augmented Generation) ---
# Uses the same GEMINI_API_KEY for embeddings (text-embedding-004 model).
# No additional keys needed — embedding proxy reuses GEMINI_API_KEY.
# Run `npm run generate-embeddings` once after setting up Supabase pgvector.
