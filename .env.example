# Glowmi Environment Variables
# Copy this file to .env and fill in the values

# Google Gemini API Key (AI beauty analysis)
# Get from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# AWS Lambda Gemini Proxy URL (production — secures API key server-side)
# When set, all Gemini API calls go through Lambda instead of Cloudflare proxy
VITE_LAMBDA_GEMINI_URL=

# Discord Webhook URL (new signup notifications)
# Only needed for Cloudflare Functions (not required for local dev)
# Set in: Cloudflare Pages > Settings > Variables and Secrets
# DISCORD_WEBHOOK_URL=
